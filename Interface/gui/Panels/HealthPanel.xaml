<UserControl x:Class="Sebastian.Panels.HealthPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource PanelStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Width="200" Background="{StaticResource SecondaryBackgroundColor}">
                <Button Content="Physical Health" Style="{StaticResource QuantumButton}"/>
                <Button Content="Mental Wellbeing" Style="{StaticResource QuantumButton}"/>
                <Button Content="PTSD Monitoring" Style="{StaticResource QuantumButton}"/>
            </StackPanel>

            <Canvas x:Name="HealthVisualizer" Grid.Column="1"/>
        </Grid>
    </Border>
</UserControl>
