<UserControl x:Class="gui.Panels.SocialFamilyPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Sidebar -->
        <StackPanel Grid.Column="0" Background="#252526">
            <TextBlock Text="Family Members" Foreground="#D4D4D4" Padding="10"/>
            <ListBox Background="Transparent"/>
            <TextBlock Text="Social Circles" Foreground="#D4D4D4" Padding="10"/>
            <ListBox Background="Transparent"/>
            <TextBlock Text="Events" Foreground="#D4D4D4" Padding="10"/>
            <ListBox Background="Transparent"/>
        </StackPanel>
        
        <!-- Main Content -->
        <Grid Grid.Column="1" Margin="20">
            <Calendar Background="#252526" Foreground="#D4D4D4"/>
        </Grid>
    </Grid>
</UserControl>
