<UserControl x:Class="gui.Panels.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Settings" Foreground="#D4D4D4" FontSize="24" Margin="0,0,0,20"/>
            
            <GroupBox Header="Theme Settings" Foreground="#D4D4D4">
                <StackPanel Margin="10">
                    <ComboBox Margin="0,5"/>
                </StackPanel>
            </GroupBox>
            
            <GroupBox Header="Functionality Settings" Foreground="#D4D4D4">
                <StackPanel Margin="10">
                    <CheckBox Content="Enable Advanced Features" Foreground="#D4D4D4"/>
                    <CheckBox Content="Enable Voice Commands" Foreground="#D4D4D4"/>
                </StackPanel>
            </GroupBox>
            
            <GroupBox Header="Personal Preferences" Foreground="#D4D4D4">
                <StackPanel Margin="10">
                    <Slider Margin="0,5"/>
                    <Slider Margin="0,5"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </Grid>
</UserControl>
