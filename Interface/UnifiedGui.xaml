<UserControl x:Class="SebastianInterface.ContractSealAnimations"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Canvas>
        <!-- Rotating Outer Ring -->
        <Path x:Name="OuterRing" Fill="#4A1C40">
            <Path.RenderTransform>
                <RotateTransform x:Name="OuterRingRotation"/>
            </Path.RenderTransform>
            <Path.Triggers>
                <EventTrigger RoutedEvent="Path.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="OuterRingRotation"
                                Storyboard.TargetProperty="Angle"
                                From="0" To="360" Duration="0:0:30"
                                RepeatBehavior="Forever"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Path.Triggers>
        </Path>

        <!-- Pulsing Core -->
        <Ellipse x:Name="CoreSeal" Fill="#8B0000">
            <Ellipse.Effect>
                <DropShadowEffect Color="#BF9B30" BlurRadius="20"/>
            </Ellipse.Effect>
            <Ellipse.Triggers>
                <EventTrigger RoutedEvent="Ellipse.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="CoreSeal"
                                Storyboard.TargetProperty="Opacity"
                                From="0.4" To="1" Duration="0:0:2"
                                AutoReverse="True"
                                RepeatBehavior="Forever"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Ellipse.Triggers>
        </Ellipse>
    </Canvas>
</UserControl>
<UserControl x:Class="SebastianInterface.DemonicEnergyVisualizer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid>
        <!-- Demonic Energy Flow -->
        <Canvas>
            <!-- Energy Streams -->
            <ItemsControl ItemsSource="{Binding EnergyStreams}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Path Stroke="#8B0000" 
                              StrokeThickness="1.5"
                              Data="{Binding StreamPath}">
                            <Path.Effect>
                                <BlurEffect Radius="3"/>
                            </Path.Effect>
                        </Path>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Contract Seal Power Nodes -->
            <ItemsControl ItemsSource="{Binding PowerNodes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Ellipse Width="10" Height="10"
                                    Fill="#BF9B30">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#4A1C40" 
                                                    BlurRadius="5"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Canvas>
    </Grid>
</UserControl>
<UserControl x:Class="SebastianInterface.HolographicCommandCenter"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid>
        <!-- Central Command Interface -->
        <Canvas>
            <!-- Holographic Rings -->
            <ItemsControl ItemsSource="{Binding CommandRings}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Ellipse Width="{Binding Diameter}" 
                                Height="{Binding Diameter}"
                                Stroke="#BF9B30"
                                StrokeThickness="1">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="{Binding Rotation}"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Effect>
                                <BlurEffect Radius="2"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Command Nodes -->
            <ItemsControl ItemsSource="{Binding CommandNodes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource HolographicButtonStyle}"
                                Command="{Binding NodeCommand}">
                            <Button.Content>
                                <Path Data="{Binding IconGeometry}"
                                      Fill="#4A1C40"/>
                            </Button.Content>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Canvas>
    </Grid>
</UserControl>
<UserControl x:Class="SebastianInterface.HolographicEffects"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Canvas>
        <!-- Quantum Field Particles -->
        <ItemsControl ItemsSource="{Binding FieldParticles}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            
            <!-- Particle Template -->
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Ellipse Width="4" Height="4" 
                             Fill="#BF9B30" Opacity="0.8">
                        <Ellipse.Effect>
                            <BlurEffect Radius="2"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Contract Seal Overlay -->
        <Path Stroke="#8B0000" StrokeThickness="1.5">
            <Path.Effect>
                <BlurEffect Radius="4"/>
            </Path.Effect>
        </Path>
    </Canvas>
</UserControl>
<UserControl x:Class="SebastianInterface.HolographicEnvironment"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid>
        <!-- Ambient Environment Effects -->
        <Canvas>
            <!-- Quantum Field Particles -->
            <ItemsControl ItemsSource="{Binding FieldParticles}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Ellipse Width="2" Height="2"
                                Fill="#4A1C40"
                                Opacity="{Binding ParticleEnergy}">
                            <Ellipse.Effect>
                                <BlurEffect Radius="1"/>
                            </Ellipse.Effect>
                            <Ellipse.RenderTransform>
                                <TranslateTransform 
                                    X="{Binding Position.X}"
                                    Y="{Binding Position.Y}"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Reality Distortion Effects -->
            <Path Data="{Binding DistortionPattern}"
                  Stroke="#BF9B30"
                  StrokeThickness="0.5">
                <Path.Effect>
                    <BlurEffect Radius="8"/>
                </Path.Effect>
            </Path>
        </Canvas>
    </Grid>
</UserControl>
<UserControl x:Class="SebastianInterface.InteractionPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid>
        <!-- Main Interaction Area -->
        <Border Background="#0A0A0F" Opacity="0.95">
            <!-- Live Interaction Display -->
            <DockPanel>
                <!-- Response Area -->
                <ScrollViewer DockPanel.Dock="Top">
                    <ItemsControl ItemsSource="{Binding Interactions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Message}"
                                         Foreground="#C0C2C9"
                                         FontFamily="Cinzel"
                                         Margin="5">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#4A1C40" 
                                                        BlurRadius="3"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Input Area -->
                <Grid DockPanel.Dock="Bottom">
                    <TextBox Text="{Binding UserInput}"
                             Background="#0A0A0F"
                             Foreground="#C0C2C9"
                             BorderBrush="#8B0000"/>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Holographic Button Style -->
    <Style x:Key="HolographicButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="ButtonBorder"
                                BorderBrush="#BF9B30"
                                BorderThickness="1"
                                Background="#0A0A0F"
                                Opacity="0.8">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" 
                                    Property="Background" Value="#4A1C40"/>
                            <Setter TargetName="ButtonBorder" 
                                    Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#8B0000" 
                                                    BlurRadius="10"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
<Window x:Class="gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sebastian Interface" Height="900" Width="1600"
        Background="{StaticResource BackgroundColor}">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="80"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="60"/>
		</Grid.RowDefinitions>

		<!-- Upper Section with Profile -->
		<Border Grid.Row="0" Style="{StaticResource PanelStyle}">
			<DockPanel>
				<Image Source="/Assets/sebastian-profile.png" Width="60" Height="60" Margin="10"/>
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
					<Button Content="Home" Style="{StaticResource NavButton}" />
					<Button Content="Control Center" Style="{StaticResource NavButton}" />
					<Button Content="Financial Suite" Style="{StaticResource NavButton}" />
					<Button Content="Health" Style="{StaticResource NavButton}" />
					<Button Content="Security" Style="{StaticResource NavButton}" />
					<Button Content="Smart Helper" Style="{StaticResource NavButton}" />
					<Button Content="Social" Style="{StaticResource NavButton}" />
					<Button Content="Advanced" Style="{StaticResource NavButton}" />
					<Button Content="Voice" Style="{StaticResource NavButton}" />
				</StackPanel>
			</DockPanel>
		</Border>

		<!-- Main Content Area -->
		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="250"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<!-- Left Sidebar -->
			<Border Grid.Column="0" Style="{StaticResource PanelStyle}" Margin="5">
				<StackPanel x:Name="SidebarPanel"/>
			</Border>

			<!-- Main Panel -->
			<Border Grid.Column="1" Style="{StaticResource PanelStyle}" Margin="5">
				<Grid x:Name="MainPanel"/>
			</Border>
		</Grid>

		<!-- Lower Section -->
		<Border Grid.Row="2" Style="{StaticResource PanelStyle}">
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
				<Button Content="Quick Access" Style="{StaticResource ActionButton}" />
				<Button Content="System Status" Style="{StaticResource ActionButton}" />
				<Button Content="Power Control" Style="{StaticResource ActionButton}" />
			</StackPanel>
		</Border>
	</Grid>
</Window>
<UserControl x:Class="SebastianInterface.QuantumMetricsDisplay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid>
        <!-- Advanced Metrics Display -->
        <Canvas>
            <!-- Field Strength Visualizer -->
            <Path x:Name="FieldStrengthPath" 
                  Stroke="#8B0000" 
                  StrokeThickness="2">
                <Path.Data>
                    <PathGeometry>
                        <!-- Dynamic field strength pattern -->
                    </PathGeometry>
                </Path.Data>
                <Path.Effect>
                    <DropShadowEffect Color="#BF9B30" 
                                    BlurRadius="10"/>
                </Path.Effect>
            </Path>

            <!-- Reality Coherence Matrix -->
            <ItemsControl ItemsSource="{Binding CoherencePoints}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Ellipse Width="3" Height="3"
                                Fill="#4A1C40"
                                Opacity="{Binding CoherenceValue}">
                            <Ellipse.Effect>
                                <BlurEffect Radius="1"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Canvas>
    </Grid>
</UserControl>
<UserControl x:Class="SebastianInterface.QuantumVisualizer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid>
        <!-- Field Strength Display -->
        <Canvas x:Name="FieldDisplay">
            <Rectangle Width="300" Height="300">
                <Rectangle.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#4A1C40" Offset="0"/>
                        <GradientStop Color="#0A0A0F" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            
            <!-- Quantum Matrix Visualization -->
            <ItemsControl ItemsSource="{Binding MatrixPoints}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                
                <!-- Matrix Point Template -->
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Line X1="{Binding X1}" Y1="{Binding Y1}"
                              X2="{Binding X2}" Y2="{Binding Y2}"
                              Stroke="#C0C2C9" StrokeThickness="0.5"
                              Opacity="{Binding Energy}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Canvas>
    </Grid>
</UserControl>
<UserControl x:Class="SebastianInterface.SebastianRenderer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid>
