<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Quantum Field Animation -->
    <Storyboard x:Key="FieldPulse">
        <DoubleAnimation 
            Storyboard.TargetProperty="Opacity"
            From="0.4" To="1.0" Duration="0:0:2"
            AutoReverse="True" RepeatBehavior="Forever"/>
    </Storyboard>

    <!-- Particle System Animation -->
    <Storyboard x:Key="ParticleFlow">
        <DoubleAnimation 
            Storyboard.TargetProperty="Opacity"
            From="0.0" To="1.0" Duration="0:0:0.5"/>
    </Storyboard>

    <!-- Status Update Animation -->
    <Storyboard x:Key="StatusUpdate">
        <ColorAnimation 
            Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
            From="#D4D4D4" To="#4A1C40" Duration="0:0:0.3"
            AutoReverse="True"/>
    </Storyboard>

    <!-- Button Hover Animation -->
    <Storyboard x:Key="ButtonHover">
        <ColorAnimation 
            Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)"
            To="#3E3E3E" Duration="0:0:0.2"/>
    </Storyboard>

    <!-- Panel Transition Animation -->
    <Storyboard x:Key="PanelTransition">
        <DoubleAnimation 
            Storyboard.TargetProperty="Opacity"
            From="0.0" To="1.0" Duration="0:0:0.3"/>
        <ThicknessAnimation 
            Storyboard.TargetProperty="Margin"
            From="0,20,0,0" To="0" Duration="0:0:0.3"/>
    </Storyboard>
</ResourceDictionary>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Quantum Control Styles -->
    <Style x:Key="QuantumControlBase" TargetType="Control">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="Foreground" Value="#D4D4D4"/>
        <Setter Property="BorderBrush" Value="#3E3E3E"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10"/>
    </Style>

    <!-- Field Visualization Controls -->
    <Style x:Key="FieldDisplay" TargetType="Canvas">
        <Setter Property="Background" Value="#252526"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <!-- Particle System Controls -->
    <Style x:Key="ParticleContainer" TargetType="ItemsControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <Canvas IsItemsHost="True"/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Status Monitor Controls -->
    <Style x:Key="StatusDisplay" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#D4D4D4"/>
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Margin" Value="5"/>
    </Style>

    <!-- Quantum Button Style -->
    <Style x:Key="QuantumButton" TargetType="Button">
        <Setter Property="Background" Value="#2D2D2D"/>
        <Setter Property="Foreground" Value="#D4D4D4"/>
        <Setter Property="BorderBrush" Value="#3E3E3E"/>
        <Setter Property="Padding" Value="15,8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3E3E3E"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#4A1C40"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

