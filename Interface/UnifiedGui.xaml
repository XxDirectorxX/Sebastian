<Application x:Class="Sebastian.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="interface/gui/Styles/SystemStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
<UserControl x:Class="Sebastian.Panels.DashboardPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Dashboard Header -->
        <TextBlock Text="Dashboard" 
                 Style="{StaticResource HeaderText}"
                 Margin="20,20,20,10"/>

        <!-- Dashboard Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Status Panel -->
            <Border Grid.Column="0" Grid.Row="0" 
                    Background="{StaticResource SecondaryColor}"
                    Margin="5">
                <TextBlock Text="System Status" 
                         Style="{StaticResource StatusText}"
                         Margin="10"/>
            </Border>

            <!-- Quantum Field Monitor -->
            <Border Grid.Column="1" Grid.Row="0"
                    Background="{StaticResource SecondaryColor}"
                    Margin="5">
                <TextBlock Text="Quantum Field Strength" 
                         Style="{StaticResource StatusText}"
                         Margin="10"/>
            </Border>

            <!-- Reality Coherence Display -->
            <Border Grid.Column="0" Grid.Row="1"
                    Background="{StaticResource SecondaryColor}"
                    Margin="5">
                <TextBlock Text="Reality Coherence" 
                         Style="{StaticResource StatusText}"
                         Margin="10"/>
            </Border>

            <!-- Performance Metrics -->
            <Border Grid.Column="1" Grid.Row="1"
                    Background="{StaticResource SecondaryColor}"
                    Margin="5">
                <TextBlock Text="Performance Metrics" 
                         Style="{StaticResource StatusText}"
                         Margin="10"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
<Window x:Class="Sebastian.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sebastian" Height="800" Width="1200"
        Background="#1E1E1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
    </Grid>
</Window>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colors -->
    <Color x:Key="PrimaryColor">#FF1A1A1A</Color>
    <Color x:Key="SecondaryColor">#FF2D2D2D</Color>
    <Color x:Key="AccentColor">#FF007ACC</Color>
    <Color x:Key="TextColor">#FFF0F0F0</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="TopNavBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="SideNavBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="BottomBarBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>

    <!-- Text Styles -->
    <Style x:Key="HeaderText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Light"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    </Style>

    <Style x:Key="StatusText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Button Styles -->
    <Style x:Key="NavButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Left" 
                                        VerticalAlignment="Center"
                                        Margin="20,0"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
