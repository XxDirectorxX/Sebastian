        <Viewport3D>
            <Viewport3D.Camera>
                <PerspectiveCamera Position="0,0,2" LookDirection="0,0,-1" UpDirection="0,1,0"/>
            </Viewport3D.Camera>
            
            <!-- Sebastian Model -->
            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <GeometryModel3D>
                        <!-- High-detail Sebastian mesh -->
                    </GeometryModel3D>
                </ModelVisual3D.Content>
            </ModelVisual3D>
        </Viewport3D>
    </Grid>
</UserControl>
<UserControl x:Class="SebastianInterface.SecurityDisplay"
